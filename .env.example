APP_NAME=LegalDesk AI Microservice
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4173,http://localhost:8080

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ENABLE_LLM_CALLS=false
LLM_MAX_RETRIES=1
LLM_RETRY_DELAY_SECONDS=0.8

DATABASE_URL=postgresql://legaldesk:legaldesk@postgres:5432/legaldesk_ai
REDIS_URL=redis://redis:6379/0
AUTH_JWT_SECRET=legaldesk-dev-jwt-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_MINUTES=720
REQUEST_TIMEOUT_SECONDS=30
HEALTHCHECK_TIMEOUT_SECONDS=2

DISCLAIMER=Kết quả AI chỉ có giá trị tham khảo, không thay thế tư vấn pháp lý chuyên nghiệp.
