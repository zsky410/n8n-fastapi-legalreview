POSTGRES_USER=legalreview
POSTGRES_PASSWORD=legalreview
POSTGRES_DB=legalreview
DATABASE_URL=postgresql+psycopg://legalreview:legalreview@postgres:5432/legalreview

SECRET_KEY=change-me-for-local-demo
ACCESS_TOKEN_EXPIRE_MINUTES=480
BACKEND_CORS_ORIGINS=http://localhost:3000

FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

N8N_WEBHOOK_URL=http://n8n:5678/webhook/document-reviewed
N8N_WEBHOOK_TIMEOUT_SECONDS=10
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=10485760
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_REVIEW_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=90
MANUAL_REVIEW_RISK_SCORE_THRESHOLD=70
OCR_ENABLED=true
OCR_LANGUAGES=vie+eng
OCR_MAX_PAGES=10
SEED_SAMPLE_DOCUMENTS=false
# Set RISK_PERSONAL_DATA_ENABLED=true to re-enable the SENSITIVE_PERSONAL_DATA
# risk finding (CCCD/phone/address detection). Disabled by default because the
# pilot dataset only contains public sample documents that users want fully
# reviewed without PII warnings.
RISK_PERSONAL_DATA_ENABLED=false
# Số ký tự văn bản trích xuất gửi cho LLM trong mỗi lần review. Tăng để AI có
# nhiều ngữ cảnh hơn, giảm nếu bạn cần tiết kiệm token.
AI_REVIEW_EXCERPT_CHARS=120000
